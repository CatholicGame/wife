{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/form", "destination": "/form.html" },
    { "source": "/form/:query*", "destination": "/form.html/:query*" },
    { "source": "/detail", "destination": "/detail.html" },
    { "source": "/detail/:query*", "destination": "/detail.html/:query*" },
    { "source": "/map", "destination": "/map.html" },
    { "source": "/stats", "destination": "/stats.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
